# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Search APIs (required for live price discovery)
SERPER_API_KEY=          # https://serper.dev — primary web search
TAVILY_API_KEY=          # https://tavily.com — page extraction
EXA_API_KEY=             # https://exa.ai — neural web search
FIRECRAWL_API_KEY=       # https://firecrawl.dev — JS-rendered pages
GROQ_API_KEY=            # https://console.groq.com — LLM extraction (free tier)
OPENROUTER_KEY=          # https://openrouter.ai — alternative LLM (optional)

# Optional enrichment
BROWSE_AI_API_KEY=       # https://browse.ai
JINA_API_KEY=            # https://jina.ai

# App config
NODE_ENV=production
PORT=3000
